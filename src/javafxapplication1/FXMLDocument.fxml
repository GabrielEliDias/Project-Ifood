<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="200" prefWidth="320" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="javafxapplication1.FXMLDocumentController">
    <children>
        <Button fx:id="button" layoutX="132.0" layoutY="144.0" onAction="#fazerLogin" prefHeight="25.0" prefWidth="58.0" text="Ok" />
        <Label fx:id="label" layoutX="64.0" layoutY="14.0" minHeight="16" minWidth="69" text="Bem-vindo ao iFood!" textAlignment="CENTER">
         <font>
            <Font name="Montserrat SemiBold" size="18.0" />
         </font></Label>
      <Label fx:id="textoLogin" layoutX="44.0" layoutY="67.0" minHeight="16" minWidth="58.0" prefHeight="23.0" prefWidth="58.0" text="Login:">
         <font>
            <Font name="Montserrat Medium" size="18.0" />
         </font>
      </Label>
      <Label fx:id="textoSenha" layoutX="44.0" layoutY="100.0" minHeight="16" minWidth="58.0" prefHeight="23.0" prefWidth="64.0" text="Senha:">
         <font>
            <Font name="Montserrat Medium" size="18.0" />
         </font>
      </Label>
      <TextField fx:id="campoLogin" layoutX="116.0" layoutY="66.0" />
      <TextField fx:id="campoSenha" layoutX="116.0" layoutY="99.0" />
    </children>
</AnchorPane>
